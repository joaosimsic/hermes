# ============================================================================
# Hermes Kubernetes Secrets - MASTER REFERENCE
# ============================================================================
# This file contains ALL secrets needed for the Hermes platform across all
# environments. Copy the relevant sections to the appropriate secrets.env
# files in each component's overlay directory.
#
# IMPORTANT:
# - DO NOT commit actual secrets.env files to version control
# - All secrets.env files are gitignored by default
# - Use strong, unique passwords for each environment (especially production)
# - Rotate secrets regularly in production
#
# For detailed setup instructions, see: infrastructure/k8s/README.md
# ============================================================================

# ----------------------------------------------------------------------------
# POSTGRES DATABASES (Auth DB & User DB)
# ----------------------------------------------------------------------------
# Location: shared/postgres/{auth-db,user-db}/overlays/{dev,staging,prod}/secrets.env
#
# Three users are created:
# 1. POSTGRES_USER - Database superuser (for admin tasks)
# 2. FLYWAY_USER - Schema migration user (for Flyway/Liquibase)
# 3. APP_USER - Application user (runtime, limited privileges)

POSTGRES_PASSWORD=change-me-postgres-admin-password
FLYWAY_PASSWORD=change-me-flyway-password
APP_PASSWORD=change-me-app-password

# ----------------------------------------------------------------------------
# RABBITMQ MESSAGE BROKER
# ----------------------------------------------------------------------------
# Location: shared/rabbitmq/overlays/{dev,staging,prod}/secrets.env

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password

# ----------------------------------------------------------------------------
# KEYCLOAK IDENTITY PROVIDER
# ----------------------------------------------------------------------------
# Location: shared/keycloak/overlays/{dev,staging,prod}/secrets.env
#
# KEYCLOAK_ADMIN - Admin console username
# KEYCLOAK_ADMIN_PASSWORD - Admin console password
# GITHUB_CLIENT_ID - GitHub OAuth App Client ID (from GitHub Developer Settings)
# GITHUB_CLIENT_SECRET - GitHub OAuth App Client Secret

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ----------------------------------------------------------------------------
# AUTH SERVICE
# ----------------------------------------------------------------------------
# Location: services/auth-service/overlays/{dev,staging,prod}/secrets.env

SPRING_DATASOURCE_PASSWORD=change-me-app-password
FLYWAY_PASSWORD=change-me-flyway-password
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password
SPRING_RABBITMQ_USERNAME=admin
SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq-password

# ----------------------------------------------------------------------------
# USER SERVICE
# ----------------------------------------------------------------------------
# Location: services/user-service/overlays/{dev,staging,prod}/secrets.env
#
# AWS credentials are used for S3 profile image storage

SPRING_DATASOURCE_PASSWORD=change-me-app-password
FLYWAY_PASSWORD=change-me-flyway-password
SPRING_RABBITMQ_USERNAME=admin
SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq-password
SPRING_CLOUD_AWS_CREDENTIALS_ACCESS_KEY=your-aws-access-key-id
SPRING_CLOUD_AWS_CREDENTIALS_SECRET_KEY=your-aws-secret-access-key

# ----------------------------------------------------------------------------
# API GATEWAY
# ----------------------------------------------------------------------------
# Location: services/gateway/overlays/{dev,staging,prod}/secrets.env
#
# GATEWAY_SECRET - JWT signing key (MUST be at least 32 characters)
# This secret MUST match the APP_JWT_SECRET in the user-service

GATEWAY_SECRET=change-me-gateway-secret-MUST-BE-LONG-32-CHARS-MIN

# ============================================================================
# ENVIRONMENT-SPECIFIC RECOMMENDATIONS
# ============================================================================

# DEVELOPMENT:
# - Use simple passwords for easier local development
# - Example: "dev-password-123"

# STAGING:
# - Use stronger passwords to simulate production
# - Example: "Staging_P@ssw0rd_2024!"

# PRODUCTION:
# - Use cryptographically strong passwords (min 32 characters)
# - Use a password manager or secrets management system
# - Consider using Kubernetes External Secrets Operator
# - Example: "aB3$xY9#mK2@pL7!qN4^rT8&wZ1*vC6%"
#
# Generate strong passwords with:
#   openssl rand -base64 32
#   or
#   pwgen -s 32 1

# ============================================================================
# SECRETS DEPLOYMENT CHECKLIST
# ============================================================================
# 
# Before deploying to any environment:
#
# 1. Copy all relevant secrets.env.example files to secrets.env
# 2. Replace all placeholder values with actual secrets
# 3. Ensure GATEWAY_SECRET matches between gateway and user-service
# 4. Verify database passwords match across services and postgres
# 5. Test the deployment in dev before promoting to staging/prod
# 6. Never commit secrets.env files to version control
# 7. Store production secrets in a secure vault (e.g., HashiCorp Vault, AWS Secrets Manager)
#
# ============================================================================
