CB_SLIDING_WINDOW_SIZE=10
CB_MINIMUM_NUMBER_OF_CALLS=5
CB_FAILURE_RATE_THRESHOLD=50
CB_WAIT_DURATION_OPEN_STATE_SECONDS=30
CB_PERMITTED_CALLS_HALF_OPEN=3
