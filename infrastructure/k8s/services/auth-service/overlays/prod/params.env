SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8082
KEYCLOAK_SERVER_URL=http://keycloak:8180
KEYCLOAK_REALM=hermes
KEYCLOAK_CLIENT_ID=hermes-app
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_DATA_REDIS_HOST=auth-redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATASOURCE_URL=jdbc:postgresql://auth-postgres:5432/postgres
SPRING_DATASOURCE_USERNAME=app_user
FLYWAY_USER=flyway_user
AUTH_COOKIE_DOMAIN=hermes.yourdomain.com
AUTH_COOKIE_SECURE=true
AUTH_ACCESS_TOKEN_MAX_AGE=300
AUTH_REFRESH_TOKEN_MAX_AGE=1800
GITHUB_REDIRECT_URI=https://hermes.yourdomain.com/auth/github/callback
