SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=staging
SPRING_DATA_REDIS_HOST=gateway-cache
SPRING_DATA_REDIS_PORT=6379
USER_SERVICE_URL=http://user-user-service:8081
AUTH_SERVICE_URL=http://auth-auth-service:8082
KC_JWKS_URL=http://keycloak:8180/realms/hermes/protocol/openid-connect/certs
KC_JWT_ISSUER=http://keycloak:8180/realms/hermes
COGNITO_JWKS_URL=https://cognito-idp.sa-east-1.amazonaws.com/your-pool-id/.well-known/jwks.json
COGNITO_JWT_ISSUER=https://cognito-idp.sa-east-1.amazonaws.com/your-pool-id
CORS_ALLOWED_ORIGINS=https://hermes-staging.yourdomain.com
CACHE_TTL_SECONDS=900
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_AUTHENTICATED_BURST=300
RATE_LIMIT_UNAUTHENTICATED=10
RATE_LIMIT_UNAUTHENTICATED_BURST=20
