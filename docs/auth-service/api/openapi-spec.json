{
  "openapi": "3.1.0",
  "info": {
    "title": "Auth Service API",
    "description": "Identity provider adapter for Keycloak/Cognito and OAuth2 flows.",
    "version": "1.0.0"
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register new user",
        "description": "Creates user in IDP and triggers 'USER_REGISTERED' event.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRequest" }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login with credentials",
        "responses": { "200": { "description": "Returns HTTP-Only Cookies" } }
      }
    },
    "/api/auth/github": {
      "get": {
        "summary": "Get GitHub OAuth URL",
        "parameters": [
          {
            "name": "redirectUri",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "GitHub redirect link" } }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string", "minLength": 8 }
        }
      }
    }
  }
}
